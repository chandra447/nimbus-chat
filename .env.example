OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENROUTER_API_KEY=
TAVILY_ENABLED=true
TAVILY_API_KEY=
SPECIALIST_CARD_REFRESH_TTL_SECONDS=300
VITE_ORCHESTRATOR_BASE_URL=http://localhost:8000

# Travel specialist (port 8001)
SPECIALIST_TYPE=travel
SPECIALIST_PORT=8001
SPECIALIST_PUBLIC_URL=http://localhost:8001
SPECIALIST_INTERNAL_URL=http://travel-specialist:8001

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*

# Internal URL specialists use to POST push notifications back to the orchestrator webhook
ORCHESTRATOR_INTERNAL_URL=http://orchestrator:8000
