OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
OPENAI_MODEL=gpt-5.4-mini

SQLITE_PATH=./data/nimbus-chat.db

ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8000
ORCHESTRATOR_PUBLIC_URL=http://localhost:8000

SPECIALIST_HOST=0.0.0.0
SPECIALIST_PORT=8001
SPECIALIST_PUBLIC_URL=http://localhost:8001

TAVILY_API_KEY=
TAVILY_ENABLED=false

# Agent-card refresh policy for Option B hybrid cache:
# 300 = refresh stale registered specialist cards every 5 minutes.
# 0 = refresh on every registry read. -1 = disable TTL refresh.
SPECIALIST_CARD_REFRESH_TTL_SECONDS=300
